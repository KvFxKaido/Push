#!/bin/sh
# The hook runs from the repo root (husky default cwd). One `pnpm install` at
# the root installs the whole workspace, so Biome (root) and ESLint (app/ — its
# config depends on app-only plugins) both come from a single install.

if [ ! -x ./node_modules/.bin/biome ]; then
  echo "[pre-commit] @biomejs/biome is not installed." >&2
  echo "[pre-commit] Run 'pnpm install' at the repo root before committing." >&2
  exit 1
fi

./node_modules/.bin/biome check --staged --no-errors-on-unmatched || exit 1

# ESLint lives in app/ because its config depends on app-only plugins. Guard
# explicitly so contributors get actionable setup guidance instead of a generic
# script failure when the workspace has not been installed.
if [ ! -x ./app/node_modules/.bin/eslint ]; then
  echo "[pre-commit] ESLint is not installed in app/node_modules." >&2
  echo "[pre-commit] Run 'pnpm install' at the repo root before committing." >&2
  exit 1
fi

pnpm --filter my-app run lint
