{
  "name": "push-root",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.10.0",
  "scripts": {
    "build": "cd app && npm install && npm run build",
    "build:cli": "cd cli && npx tsc -p tsconfig.json",
    "build:mcp:github": "cd mcp/github-server && npm run build",
    "check:design-tokens": "npm --prefix app run check:design-tokens --",
    "dev:cli": "node --import tsx cli/cli.ts",
    "dev:cli:bun": "bun --no-env-file cli/cli.ts",
    "dev:mcp:github": "cd mcp/github-server && npm run dev",
    "format": "biome format --write",
    "format:check": "biome format",
    "gen:schema": "node --import tsx scripts/gen-protocol-schema.mjs",
    "lint": "npm --prefix app run lint",
    "r2:snapshots:lifecycle": "npx wrangler r2 bucket lifecycle add push-cf-snapshots --expire-days 7",
    "test:cli": "node --import tsx --import ./cli/tests/setup-test-home-isolation.mjs --test cli/tests/*.test.mjs",
    "test:mcp:github": "cd mcp/github-server && npm test",
    "typecheck": "cd cli && npx tsc --noEmit",
    "typecheck:mcp:github": "cd mcp/github-server && npm run typecheck",
    "typecheck:all": "npx tsc --noEmit -p cli/tsconfig.json && npm --prefix mcp/github-server run typecheck && npm --prefix app run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2"
  },
  "dependencies": {
    "react": "^19.2.7",
    "silvery": "0.21.1",
    "ws": "^8.21.0",
    "zod": "^4.3.5"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
