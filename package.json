{
  "name": "push-root",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "prepare": "husky app/.husky",
    "build": "pnpm --filter my-app run build",
    "build:cli": "cd cli && pnpm exec tsc -p tsconfig.json",
    "build:mcp:github": "pnpm --filter @push/github-mcp-server run build",
    "check:design-tokens": "pnpm --filter my-app run check:design-tokens --",
    "dev:cli": "node --import tsx cli/cli.ts",
    "dev:cli:bun": "bun --no-env-file cli/cli.ts",
    "dev:mcp:github": "pnpm --filter @push/github-mcp-server run dev",
    "format": "biome format --write",
    "format:check": "biome format",
    "gen:schema": "node --import tsx scripts/gen-protocol-schema.mjs",
    "lint": "pnpm --filter my-app run lint",
    "r2:snapshots:lifecycle": "pnpm dlx wrangler r2 bucket lifecycle add push-cf-snapshots --expire-days 7",
    "test:cli": "node --import tsx --import ./cli/tests/setup-test-home-isolation.mjs --test cli/tests/*.test.mjs",
    "test:mcp:github": "pnpm --filter @push/github-mcp-server test",
    "typecheck": "cd cli && pnpm exec tsc --noEmit",
    "typecheck:mcp:github": "pnpm --filter @push/github-mcp-server run typecheck",
    "typecheck:all": "pnpm exec tsc --noEmit -p cli/tsconfig.json && pnpm --filter @push/github-mcp-server run typecheck && pnpm --filter my-app run typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/ws": "^8.18.1",
    "husky": "^9.1.7",
    "tsx": "^4.23.0",
    "typescript": "~7.0.2"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "^19.2.7",
    "silvery": "0.21.1",
    "ws": "^8.21.1",
    "zod": "^4.3.5"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0"
  },
  "engines": {
    "node": ">=24"
  }
}
