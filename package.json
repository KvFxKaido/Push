{
  "name": "push-root",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd app && npm install && npm run build",
    "build:cli": "cd cli && npx tsc -p tsconfig.json",
    "build:mcp:github": "cd mcp/github-server && npm run build",
    "dev:cli": "node --import tsx cli/cli.ts",
    "dev:mcp:github": "cd mcp/github-server && npm run dev",
    "format": "biome format --write",
    "format:check": "biome format",
    "test:cli": "node --import tsx --test cli/tests/*.test.mjs",
    "test:mcp:github": "cd mcp/github-server && npm test",
    "typecheck": "cd cli && npx tsc --noEmit",
    "typecheck:mcp:github": "cd mcp/github-server && npm run typecheck",
    "typecheck:tsgo": "cd cli && npx tsgo --noEmit -p tsconfig.json && cd ../mcp/github-server && npx tsgo --noEmit -p tsconfig.json && cd ../../app && npx tsgo --noEmit -p tsconfig.app.json && npx tsgo --noEmit -p tsconfig.node.json"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.4",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "tsx": "^4.19.0",
    "typescript": "^6.0.2"
  }
}
