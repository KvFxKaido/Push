{
  "name": "push",
  "main": "./app/worker.ts",
  "build": {
    "command": "cd app && npm run build",
    "watch_dir": "./app/src"
  },
  // Bumped from 2026-02-01 on 2026-04-20 when adding Cloudflare Sandbox SDK.
  // Sandbox SDK ships with the post-GA runtime; recent date unlocks it.
  "compatibility_date": "2026-04-20",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "./app/dist",
    // Bind the assets layer so the Worker can call `env.ASSETS.fetch()` in its
    // SPA fallback (worker.ts). Without this binding `env.ASSETS` is undefined,
    // and any Worker-reached path that matches no route (e.g. a browser GET on
    // a POST-only API route, or /favicon.ico) crashes the fallback with
    // "Cannot read properties of undefined (reading 'fetch')" → 500. Normal
    // navigation never hit this because the assets layer serves the SPA
    // directly without invoking the Worker.
    "binding": "ASSETS"
  },
  // Sandbox backend selector — read by worker.ts to route /api/sandbox/*
  // POST requests to either handleSandbox (Modal) or handleCloudflareSandbox.
  // Values: "modal" | "cloudflare". Cloudflare is the current default;
  // Modal stays available as the fallback while CF-specific gaps (owner
  // tokens, snapshots, workspace-revision parity) are closed in follow-up
  // PRs. Flip back with: `npx wrangler deploy --var PUSH_SANDBOX_PROVIDER:modal`
  // or edit this file and redeploy.
  "vars": {
    "PUSH_SANDBOX_PROVIDER": "cloudflare",
    "PUSH_RELAY_ENABLED": "1",
    // Autonomous webhook PR reviewer (docs/runbooks/Enabling Autonomous PR
    // Review.md). Provider/model/Go-route are non-secret config, so they live
    // here in plain sight rather than as opaque secrets — the matching API key
    // (ZEN_API_KEY) and the HMAC webhook secret (GITHUB_WEBHOOK_SECRET) stay in
    // the secret store. PR_REVIEW_ZEN_GO routes the reviewer through the
    // OpenCode Zen "Go" endpoint; the Worker's Go handler translates any
    // Anthropic-transport Go models to OpenAI-shaped SSE for the DO pump.
    "PR_REVIEW_PROVIDER": "zen",
    "PR_REVIEW_MODEL": "glm-5.1",
    "PR_REVIEW_ZEN_GO": "1",
    // AI Gateway routing allow-lists. Non-secret (bare provider names, no
    // account-bound identifiers), so they live here rather than as opaque
    // secrets — the account-bound CF_AI_GATEWAY_ACCOUNT_ID / CF_AI_GATEWAY_SLUG
    // stay in the secret store. Tracking them here makes prod match local
    // instead of drifting: they were env-only, so prod lagged and
    // `custom-nvidia` stayed dormant (see worker-providers.ts "dormant until
    // nvidia is registered + listed in CF_AI_GATEWAY_CUSTOM_SLUGS").
    //   - CUSTOM_SLUGS: which `custom-*` providers are registered + enabled on
    //     the gateway (an unlisted custom slug 404s → falls back to direct).
    //     Gateway PASSTHROUGH (Push's own key in the header) is what this
    //     enables; verified working for all four.
    //   - BYOK: providers whose key the GATEWAY injects — the Worker
    //     dispatches keyless. An entry here asserts injection is VERIFIED,
    //     not merely that a key was saved in the dashboard, because a bad
    //     entry does NOT fail loudly: nvidia keyless HANGS at the gateway to
    //     the Worker's full timeout (probed 2026-07-09), and providers with
    //     anonymous tiers can silently serve misattributed traffic instead
    //     of 401ing. Verification standard before adding an id: a keyless
    //     chat probe through the gateway must return a fast, AUTHENTICATED
    //     response while the same request direct-to-upstream fails without a
    //     key. Probe with a PAID-tier model — a free-tier model (zen's
    //     big-pickle) returns FreeUsageLimitError from quota exhaustion on
    //     BOTH auth states, which is how zen was misdiagnosed as
    //     injection-broken. Verified: fireworks, sakana, ollama, zen
    //     (glm-5.1 keyless → authenticated 200 on both /zen/v1 and
    //     /zen/go/v1 paths), zai (glm-5.2 keyless → authenticated 200 via
    //     custom-zai; byok:"default" in the gateway log, probed 2026-07-10),
    //     grok (=xAI; FIRST-PARTY gateway provider, NOT custom — routes via
    //     /grok/v1/responses, grok-4.5 keyless → authenticated 200, probed
    //     2026-07-10); first-party ids verified in the AIG v2 arc.
    // Zen BYOK caveat: injection covers the openai-transport routes only.
    // The anthropic-transport Go path (/zen/go/v1/messages — MiniMax/Qwen)
    // wants x-api-key, which injection doesn't set (verified 401 keyless),
    // so those models still need ZEN_API_KEY or a user key; the Go handler
    // enforces the split. Nvidia is passthrough-only (CUSTOM_SLUGS without
    // BYOK) until its injection passes the probe above.
    "CF_AI_GATEWAY_CUSTOM_SLUGS": "ollama,sakana,fireworks,nvidia,zen,zai,moonshot",
    "CF_AI_GATEWAY_BYOK": "anthropic,deepseek,openai,google,openrouter,sakana,ollama,fireworks,zen,zai,moonshot,grok"
  },
  // API auth is the GitHub-identity session gate (auth rework — see
  // docs/decisions/Auth Rework — GitHub as the Single Identity Anchor.md). The
  // universal /api/* gate requires a valid session for an allowlisted GitHub
  // user; set the secrets PUSH_SESSION_SECRET + GITHUB_ALLOWED_USER_IDS (+
  // PUSH_SESSION_GATE_ENFORCE=1 to enforce). The retired X-Push-Deployment-Token
  // is gone; Cloudflare Access in front of the hostname remains an optional
  // outer edge gate.
  // Worker bundle shim — `import.meta.env` is Vite-only (client build). The
  // Worker runtime doesn't have it, so transitive imports of client modules
  // (via `@/lib/*` chains from coder-job-do.ts, etc.) that read
  // `import.meta.env.VITE_*` at module load would crash deploy validation with
  // `TypeError: Cannot read properties of undefined (reading 'VITE_*')`.
  // esbuild's `define` only accepts entity names or JS literals (not object
  // literals), so we enumerate each VITE_ var individually as an empty
  // string. Vite's client build handles its own `import.meta.env` replacement
  // separately and is unaffected.
  //
  // Keep this list in sync with any new `VITE_*` accesses introduced in
  // client code that may land in the Worker bundle via transitive imports.
  "define": {
    "import.meta.env.DEV": "false",
    "import.meta.env.PROD": "true",
    "import.meta.env.MODE": "\"production\"",
    "import.meta.env.BASE_URL": "\"/\"",
    "import.meta.env.SSR": "true",
    "import.meta.env.VITE_ANTHROPIC_API_KEY": "\"\"",
    "import.meta.env.VITE_API_BASE_URL": "\"\"",
    "import.meta.env.VITE_DEEPSEEK_API_KEY": "\"\"",
    "import.meta.env.VITE_FIREWORKS_API_KEY": "\"\"",
    "import.meta.env.VITE_GITHUB_APP_REDIRECT_URI": "\"\"",
    "import.meta.env.VITE_GITHUB_CLIENT_ID": "\"\"",
    "import.meta.env.VITE_GITHUB_OAUTH_PROXY": "\"\"",
    "import.meta.env.VITE_GITHUB_REDIRECT_URI": "\"\"",
    "import.meta.env.VITE_GITHUB_TOKEN": "\"\"",
    "import.meta.env.VITE_GITHUB_TOOL_BACKEND": "\"\"",
    "import.meta.env.VITE_GOOGLE_API_KEY": "\"\"",
    "import.meta.env.VITE_LOCAL_PC_MODE": "\"\"",
    "import.meta.env.VITE_NATIVE_WORKING_COPY": "\"\"",
    "import.meta.env.VITE_NVIDIA_API_KEY": "\"\"",
    "import.meta.env.VITE_OLLAMA_API_KEY": "\"\"",
    "import.meta.env.VITE_OPENAI_API_KEY": "\"\"",
    "import.meta.env.VITE_OPENROUTER_API_KEY": "\"\"",
    "import.meta.env.VITE_OPENROUTER_TRANSPORT": "\"\"",
    "import.meta.env.VITE_RELAY_MODE": "\"\"",
    "import.meta.env.VITE_SAKANA_API_KEY": "\"\"",
    "import.meta.env.VITE_TAVILY_API_KEY": "\"\"",
    "import.meta.env.VITE_USE_STREAMDOWN": "\"\"",
    "import.meta.env.VITE_XAI_API_KEY": "\"\"",
    "import.meta.env.VITE_ZAI_API_KEY": "\"\"",
    "import.meta.env.VITE_KIMI_API_KEY": "\"\"",
    "import.meta.env.VITE_HUGGINGFACE_API_KEY": "\"\"",
    "import.meta.env.VITE_ZEN_API_KEY": "\"\""
  },
  // Native Workers AI binding for the Cloudflare provider path. This is a
  // deployment-level capability, not a browser-side API key.
  "ai": {
    "binding": "AI",
    "remote": true
  },
  "ratelimits": [
    {
      "name": "RATE_LIMITER",
      // Unique integer string per CF account. Change if you have multiple rate-limiting namespaces.
      "namespace_id": "1001",
      "simple": {
        "limit": 120,
        "period": 60
      }
    }
  ],
  // Snapshot index — pointer-only KV namespace for the Modal Sandbox Snapshots
  // design (docs/decisions/Modal Sandbox Snapshots Design.md §6, Phase 4). Stores
  // `snapshot:<repoFullName>:<branch>` → { imageId, createdAt, lastAccessedAt, ... }.
  // Per-user keying is deferred; see the module header in
  // app/src/worker/snapshot-index.ts. Snapshot bytes themselves live as Modal
  // Images — this index is a thin pointer layer used for resume lookups and
  // the daily eviction cron.
  // Sandbox owner-token store — per-provider KV binding for Cloudflare's
  // /api/sandbox-cf/* path. Must be added by the operator before the CF
  // path is usable, to avoid committing a placeholder id that would break
  // `wrangler deploy`. Add manually after running:
  //
  //   npx wrangler kv:namespace create SANDBOX_TOKENS
  //
  // Then insert into the kv_namespaces array below:
  //   { "binding": "SANDBOX_TOKENS", "id": "<returned id>" }
  //
  // Until the binding is added, /api/sandbox-cf/* routes fail closed with
  // NOT_CONFIGURED 503 (including create). Modal path is unaffected.
  // Renderable artifact store — model-emitted HTML/React/Mermaid/file-tree
  // payloads persist here per chat scope. Same fail-closed contract as
  // SANDBOX_TOKENS above: when the binding is missing every /api/artifacts/*
  // route returns NOT_CONFIGURED 503 so the operator notices. Add manually
  // after running:
  //
  //   npx wrangler kv:namespace create ARTIFACTS
  //
  // Then insert into the kv_namespaces array below:
  //   { "binding": "ARTIFACTS", "id": "<returned id>" }
  // Chat library — user-scoped persistent attachments. Same fail-closed
  // contract: /api/library/* returns NOT_CONFIGURED 503 when the binding
  // is missing. The CHAT_LIBRARY binding below is wired for this
  // deployment. Operators forking the repo into a fresh CF account
  // create their own namespace via:
  //
  //   npx wrangler kv:namespace create CHAT_LIBRARY
  //
  // …then swap the id in the kv_namespaces array below.
  "kv_namespaces": [
    {
      "binding": "SNAPSHOT_INDEX",
      "id": "6c446991cc304964a421db73c189d8a8"
    },
    {
      "binding": "SANDBOX_TOKENS",
      "id": "7065ef8c73b94b5d945971c45aadb3e9"
    },
    {
      "binding": "ARTIFACTS",
      "id": "8fd209d7301d40d1a7a02eb88934bf8e"
    },
    {
      "binding": "CHAT_LIBRARY",
      "id": "cea06bc65f86466693b79921d3426c43"
    }
  ],
  // The zen provider key, bound from the SAME Secrets Store entry the AI
  // Gateway injects from (one custody point; rotate in Secrets Store and both
  // consumers follow). Exists because gateway BYOK cannot serve the
  // anthropic-transport Zen Go path: /zen/go/v1/messages authenticates via
  // `x-api-key`, and custom-provider injection sets `Authorization` only — so
  // the Worker resolves the key itself for exactly that transport
  // (handleZenGoChat). The secret carries scopes [ai_gateway, workers].
  "secrets_store_secrets": [
    {
      "binding": "ZEN_KEY_STORE",
      "store_id": "13a7421a93df46e6bea9230445e057fd",
      "secret_name": "push-gate_zen_default"
    }
  ],
  // R2 bucket backing Cloudflare-provider filesystem snapshots. Stores a
  // base64 tar.gz of /workspace (source + .git, minus node_modules/build
  // caches) keyed by an opaque snapshot id. Provision before deploy:
  //   npx wrangler r2 bucket create push-cf-snapshots
  // Retention: superseded objects are deleted inline on the next hibernate, and
  // the daily cron (triggers.crons) reaps any object no longer referenced by a
  // live snapshot-index entry. As a belt-and-suspenders backstop, set a 7-day
  // R2 lifecycle rule (matches the snapshot-index TTL) — one-time, out-of-band:
  //   npm run r2:snapshots:lifecycle
  // (i.e. `wrangler r2 bucket lifecycle add push-cf-snapshots --expire-days 7`).
  "r2_buckets": [
    {
      "binding": "SNAPSHOTS",
      "bucket_name": "push-cf-snapshots"
    }
  ],
  // Cloudflare Sandbox SDK — the default sandbox backend when
  // PUSH_SANDBOX_PROVIDER is "cloudflare" (see `vars` above). Modal stays
  // available as a fallback by redeploying with PUSH_SANDBOX_PROVIDER=modal.
  // Version must match @cloudflare/sandbox in app/package.json
  // (Dockerfile.sandbox pins the matching image tag).
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile.sandbox",
      // "standard" = 4 GiB / ½ vCPU. "basic" (1 GiB / ¼ vCPU) gets OOM-killed
      // by repo test suites — node --test / vitest size their worker pools for
      // the host CPU count, and the kernel killing the container takes the
      // whole sandbox (and the session riding on it) with it. Pairs with the
      // per-exec resource env caps in worker-cf-sandbox.ts.
      "instance_type": "standard",
      "max_instances": 10
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      },
      {
        "name": "CoderJob",
        "class_name": "CoderJob"
      },
      {
        "name": "RELAY_SESSIONS",
        "class_name": "RelaySessionDO"
      },
      {
        "name": "PrReviewJob",
        "class_name": "PrReviewJob"
      },
      {
        "name": "RUN_HOST",
        "class_name": "RunHost"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    },
    {
      "tag": "v2",
      "new_sqlite_classes": ["CoderJob"]
    },
    {
      "tag": "v3",
      // Remote Sessions relay (Phase 2.b). Declared as
      // `new_sqlite_classes` per Cloudflare's current requirement that
      // all new DO namespaces use the SQLite storage backend (legacy
      // `new_classes` is rejected at deploy validation). This does NOT
      // contradict the "no durable storage" decision in Q#2 of
      // docs/decisions/Remote Sessions via pushd Relay.md — the
      // enforcement is in code (RelaySessionDO never calls
      // state.storage.*), not in the migration flag. The flag only
      // controls which storage API is available to the DO; whether
      // that API is used is a code-level decision.
      "new_sqlite_classes": ["RelaySessionDO"]
    },
    {
      "tag": "v4",
      // PrReviewJob — autonomous webhook-triggered advisory PR reviews. SQLite
      // backend holds per-PR review status + an event log (dedupe by delivery
      // id, coalesce by head SHA). See docs/decisions/Webhook-Triggered PR Review.md.
      "new_sqlite_classes": ["PrReviewJob"]
    },
    {
      "tag": "v5",
      // RunHost — Durable Runs (Adopt-on-Silence) track. The namespace is
      // durable infrastructure (Phase 2 puts the adoption loop + checkpoint
      // persistence here); its current contents are the Phase-0 latency-spike
      // endpoints only, which use no durable storage. See
      // docs/decisions/Durable Runs — Adopt-on-Silence.md.
      "new_sqlite_classes": ["RunHost"]
    }
  ],
  // Daily snapshot index walk — emits aggregate metrics so we can size the
  // per-user LRU eviction policy once user identity lands in the keys.
  "triggers": {
    "crons": ["0 3 * * *"]
  },
  "analytics_engine_datasets": [{ "binding": "PROVIDER_STATS", "dataset": "push_provider_stats" }],
  // Workers Observability — both surfaces are CF-native and render in the
  // dashboard (Workers & Pages → push → Observability), no external service.
  //   - logs:   structured console.log({...JSON}) becomes searchable history,
  //             not just live `wrangler tail` (what we lacked when the sandbox
  //             NOT_FOUND debug forced tail-and-reproduce).
  //   - traces: native Workers Traces (GA 2026-03) — per-request execution
  //             spans (timing/CPU/outcome) in Workers Analytics → Traces.
  //             NOT OpenTelemetry: CF has no OTLP *ingest*; its OTel story is
  //             *export* (a tail worker shipping trace events out). Workers
  //             Traces is the keep-it-in-Cloudflare answer — config-only.
  // 100% head sampling: single-user volume is far under the 10M-span free tier,
  // and the point is to see everything, not sample it away.
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  }
}
