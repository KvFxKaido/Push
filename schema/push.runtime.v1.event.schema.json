{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://push.dev/schema/push.runtime.v1.event.schema.json",
  "title": "Push runtime event envelope (push.runtime.v1)",
  "description": "Unidirectional broadcast envelope emitted by the pushd daemon and the Worker relay. Generated from lib/protocol-schema.ts validators; do not hand-edit. Relay-control envelopes (other `kind` values) are out of scope.",
  "type": "object",
  "required": [
    "v",
    "kind",
    "sessionId",
    "seq",
    "ts",
    "type",
    "payload"
  ],
  "properties": {
    "v": {
      "const": "push.runtime.v1"
    },
    "kind": {
      "const": "event"
    },
    "sessionId": {
      "type": "string",
      "minLength": 1
    },
    "runId": {
      "type": "string",
      "minLength": 1
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "ts": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "type": {
      "type": "string",
      "minLength": 1
    },
    "payload": {
      "type": "object"
    }
  },
  "$defs": {
    "AssistantPromptSnapshot": {
      "type": "object",
      "required": [
        "round",
        "role",
        "totalChars",
        "sections"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 0
        },
        "role": {
          "type": "string",
          "enum": [
            "orchestrator",
            "explorer",
            "coder",
            "reviewer",
            "auditor"
          ]
        },
        "totalChars": {
          "type": "integer",
          "minimum": 0
        },
        "sections": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "hash",
              "size",
              "volatile"
            ],
            "properties": {
              "hash": {
                "type": "number"
              },
              "size": {
                "type": "integer",
                "minimum": 0
              },
              "volatile": {
                "type": "boolean"
              }
            }
          }
        }
      }
    },
    "ContextCompaction": {
      "type": "object",
      "required": [
        "round",
        "phase",
        "beforeTokens",
        "afterTokens",
        "messagesDropped"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 0
        },
        "phase": {
          "type": "string",
          "enum": [
            "summarization",
            "digest_drop",
            "hard_trim"
          ]
        },
        "beforeTokens": {
          "type": "integer",
          "minimum": 0
        },
        "afterTokens": {
          "type": "integer",
          "minimum": 0
        },
        "messagesDropped": {
          "type": "integer",
          "minimum": 0
        },
        "provider": {
          "type": "string"
        },
        "cause": {
          "type": "string",
          "enum": [
            "tool_output",
            "long_message",
            "mixed"
          ]
        }
      }
    },
    "SessionStateChanged": {
      "type": "object",
      "required": [
        "provider",
        "model"
      ],
      "properties": {
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "roleRouting": {
          "type": "object"
        }
      }
    },
    "SubagentStarted": {
      "type": "object",
      "required": [
        "executionId",
        "agent"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "planner",
            "coder",
            "explorer",
            "reviewer",
            "deep_reviewer",
            "auditor",
            "task_graph"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "SubagentCompleted": {
      "type": "object",
      "required": [
        "executionId",
        "agent",
        "summary"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "planner",
            "coder",
            "explorer",
            "reviewer",
            "deep_reviewer",
            "auditor",
            "task_graph"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "orchestratorBytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "SubagentFailed": {
      "type": "object",
      "required": [
        "executionId",
        "agent",
        "error"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "planner",
            "coder",
            "explorer",
            "reviewer",
            "deep_reviewer",
            "auditor",
            "task_graph"
          ]
        },
        "error": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "TaskGraphTaskReadyOrStarted": {
      "type": "object",
      "required": [
        "executionId",
        "taskId",
        "agent"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "explorer",
            "coder"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "TaskGraphTaskCompleted": {
      "type": "object",
      "required": [
        "executionId",
        "taskId",
        "agent",
        "summary"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "explorer",
            "coder"
          ]
        },
        "summary": {
          "type": "string"
        },
        "elapsedMs": {
          "type": "number"
        }
      }
    },
    "TaskGraphTaskFailed": {
      "type": "object",
      "required": [
        "executionId",
        "taskId",
        "agent",
        "error"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "explorer",
            "coder"
          ]
        },
        "error": {
          "type": "string",
          "minLength": 1
        },
        "elapsedMs": {
          "type": "number"
        }
      }
    },
    "TaskGraphTaskCancelled": {
      "type": "object",
      "required": [
        "executionId",
        "taskId",
        "agent",
        "reason"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "taskId": {
          "type": "string",
          "minLength": 1
        },
        "agent": {
          "type": "string",
          "enum": [
            "explorer",
            "coder"
          ]
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "elapsedMs": {
          "type": "number"
        }
      }
    },
    "TaskGraphGraphCompleted": {
      "type": "object",
      "required": [
        "executionId",
        "summary",
        "success",
        "aborted",
        "nodeCount",
        "totalRounds",
        "wallTimeMs"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "success": {
          "type": "boolean"
        },
        "aborted": {
          "type": "boolean"
        },
        "nodeCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalRounds": {
          "type": "integer",
          "minimum": 0
        },
        "wallTimeMs": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "AssistantTextChunk": {
      "type": "object",
      "required": [
        "text"
      ],
      "properties": {
        "text": {
          "type": "string"
        }
      }
    },
    "AssistantCitations": {
      "type": "object",
      "required": [
        "citations"
      ],
      "properties": {
        "citations": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "url",
              "title",
              "content"
            ],
            "properties": {
              "url": {
                "type": "string",
                "minLength": 1
              },
              "title": {
                "type": "string"
              },
              "content": {
                "type": "string"
              },
              "startIndex": {
                "type": "integer",
                "minimum": 0
              },
              "endIndex": {
                "type": "integer",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "ToolCall": {
      "type": "object",
      "required": [
        "toolName",
        "args"
      ],
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1
        },
        "args": {
          "type": "object"
        }
      }
    },
    "ToolResult": {
      "type": "object",
      "required": [
        "toolName",
        "isError"
      ],
      "properties": {
        "toolName": {
          "type": "string",
          "minLength": 1
        },
        "isError": {
          "type": "boolean"
        },
        "text": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "durationMs": {
          "type": "number"
        },
        "branch": {
          "type": "string"
        },
        "diff": {
          "type": "object",
          "required": [
            "path",
            "adds",
            "dels",
            "lines"
          ],
          "properties": {
            "path": {
              "type": "string",
              "minLength": 1
            },
            "adds": {
              "type": "number"
            },
            "dels": {
              "type": "number"
            },
            "lines": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "kind",
                  "text"
                ],
                "properties": {
                  "kind": {
                    "type": "string",
                    "enum": [
                      "add",
                      "del",
                      "ctx"
                    ]
                  },
                  "text": {
                    "type": "string"
                  },
                  "oldLine": {
                    "type": "number"
                  },
                  "newLine": {
                    "type": "number"
                  },
                  "textTruncated": {
                    "type": "boolean"
                  }
                }
              }
            },
            "truncated": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "BranchDesync": {
      "type": "object",
      "required": [
        "expected",
        "actual",
        "command"
      ],
      "properties": {
        "expected": {
          "type": "string",
          "minLength": 1
        },
        "actual": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ToolCallMalformed": {
      "type": "object",
      "required": [
        "reason"
      ],
      "properties": {
        "reason": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ErrorEvent": {
      "type": "object",
      "required": [
        "message"
      ],
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        }
      }
    },
    "WarningEvent": {
      "type": "object",
      "properties": {
        "message": {
          "type": "string",
          "minLength": 1
        },
        "code": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "message"
          ]
        },
        {
          "required": [
            "code"
          ]
        }
      ]
    },
    "StatusEvent": {
      "type": "object",
      "properties": {
        "detail": {
          "type": "string",
          "minLength": 1
        },
        "phase": {
          "type": "string",
          "minLength": 1
        }
      },
      "anyOf": [
        {
          "required": [
            "detail"
          ]
        },
        {
          "required": [
            "phase"
          ]
        }
      ]
    },
    "ApprovalRequired": {
      "type": "object",
      "required": [
        "approvalId",
        "kind",
        "title",
        "summary",
        "options"
      ],
      "properties": {
        "approvalId": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        },
        "options": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "ApprovalReceived": {
      "type": "object",
      "required": [
        "approvalId",
        "decision"
      ],
      "properties": {
        "approvalId": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "approve",
            "deny"
          ]
        },
        "by": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "RunComplete": {
      "type": "object",
      "required": [
        "outcome"
      ],
      "properties": {
        "outcome": {
          "type": "string",
          "enum": [
            "success",
            "completed",
            "failed",
            "aborted",
            "max_rounds"
          ]
        },
        "summary": {
          "type": "string"
        },
        "runId": {
          "type": "string"
        }
      }
    },
    "SessionStarted": {
      "type": "object",
      "required": [
        "sessionId",
        "state"
      ],
      "properties": {
        "sessionId": {
          "type": "string",
          "minLength": 1
        },
        "state": {
          "type": "string",
          "enum": [
            "idle",
            "running"
          ]
        },
        "mode": {
          "type": "string"
        },
        "provider": {
          "type": "string"
        },
        "sandboxProvider": {
          "type": "string"
        }
      }
    },
    "UserMessage": {
      "type": "object",
      "required": [
        "chars",
        "preview"
      ],
      "properties": {
        "chars": {
          "type": "integer",
          "minimum": 0
        },
        "preview": {
          "type": "string"
        }
      }
    },
    "ContextCompacted": {
      "type": "object",
      "required": [
        "preserveTurns",
        "totalTurns",
        "compactedMessages",
        "removedCount",
        "beforeTokens",
        "afterTokens"
      ],
      "properties": {
        "preserveTurns": {
          "type": "integer",
          "minimum": 0
        },
        "totalTurns": {
          "type": "integer",
          "minimum": 0
        },
        "compactedMessages": {
          "type": "integer",
          "minimum": 0
        },
        "removedCount": {
          "type": "integer",
          "minimum": 0
        },
        "beforeTokens": {
          "type": "integer",
          "minimum": 0
        },
        "afterTokens": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "SessionReverted": {
      "type": "object",
      "required": [
        "turns",
        "removedCount",
        "totalTurns",
        "remainingTurns",
        "remainingMessages"
      ],
      "properties": {
        "turns": {
          "type": "integer",
          "minimum": 0
        },
        "removedCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalTurns": {
          "type": "integer",
          "minimum": 0
        },
        "remainingTurns": {
          "type": "integer",
          "minimum": 0
        },
        "remainingMessages": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "SessionUnreverted": {
      "type": "object",
      "required": [
        "restoredCount",
        "totalMessages"
      ],
      "properties": {
        "restoredCount": {
          "type": "integer",
          "minimum": 0
        },
        "totalMessages": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "RunRecovered": {
      "type": "object",
      "required": [
        "originalRunId",
        "recoveryRunId",
        "policy",
        "markerAge"
      ],
      "properties": {
        "originalRunId": {
          "type": "string",
          "minLength": 1
        },
        "recoveryRunId": {
          "type": "string",
          "minLength": 1
        },
        "policy": {
          "type": "string",
          "minLength": 1
        },
        "markerAge": {
          "type": "number"
        }
      }
    },
    "RecoverySkipped": {
      "type": "object",
      "required": [
        "originalRunId",
        "reason",
        "policy",
        "markerAge"
      ],
      "properties": {
        "originalRunId": {
          "type": "string",
          "minLength": 1
        },
        "reason": {
          "type": "string",
          "minLength": 1
        },
        "policy": {
          "type": "string",
          "minLength": 1
        },
        "markerAge": {
          "type": "number"
        }
      }
    },
    "DelegationInterrupted": {
      "type": "object",
      "required": [
        "originalRunId",
        "recoveryRunId",
        "subagents",
        "graphs"
      ],
      "properties": {
        "originalRunId": {
          "type": "string",
          "minLength": 1
        },
        "recoveryRunId": {
          "type": "string",
          "minLength": 1
        },
        "subagents": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "subagentId",
              "agent"
            ],
            "properties": {
              "subagentId": {
                "type": "string",
                "minLength": 1
              },
              "agent": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "graphs": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "executionId"
            ],
            "properties": {
              "executionId": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    },
    "TurnRoute": {
      "type": "object",
      "required": [
        "route",
        "reason",
        "intent",
        "repoBranchReady"
      ],
      "properties": {
        "route": {
          "type": "string",
          "enum": [
            "orchestrator",
            "inline-delegation",
            "background-mode"
          ]
        },
        "reason": {
          "type": "string",
          "enum": [
            "conversational_inline",
            "conversational_escape_hatch",
            "conversational_downgrade"
          ]
        },
        "suppressedRoute": {
          "type": "string",
          "enum": [
            "inline-delegation",
            "background-mode"
          ]
        },
        "intent": {
          "type": "string",
          "enum": [
            "conversational",
            "task"
          ]
        },
        "repoBranchReady": {
          "type": "boolean"
        }
      }
    },
    "AssistantTurnStart": {
      "type": "object",
      "required": [
        "round"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "AssistantTurnEnd": {
      "type": "object",
      "required": [
        "round",
        "outcome"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 0
        },
        "outcome": {
          "type": "string",
          "enum": [
            "completed",
            "continued",
            "error",
            "aborted",
            "steered"
          ]
        }
      }
    },
    "HarnessAdaptation": {
      "type": "object",
      "required": [
        "round",
        "fromMaxRounds",
        "toMaxRounds",
        "reasons"
      ],
      "properties": {
        "round": {
          "type": "integer",
          "minimum": 0
        },
        "fromMaxRounds": {
          "type": "integer",
          "minimum": 0
        },
        "toMaxRounds": {
          "type": "integer",
          "minimum": 0
        },
        "reasons": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "JobStarted": {
      "type": "object",
      "required": [
        "executionId",
        "role"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "orchestrator",
            "explorer",
            "coder",
            "reviewer",
            "auditor"
          ]
        },
        "detail": {
          "type": "string"
        }
      }
    },
    "JobCompleted": {
      "type": "object",
      "required": [
        "executionId",
        "role",
        "summary"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "orchestrator",
            "explorer",
            "coder",
            "reviewer",
            "auditor"
          ]
        },
        "summary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "JobFailed": {
      "type": "object",
      "required": [
        "executionId",
        "role",
        "error"
      ],
      "properties": {
        "executionId": {
          "type": "string",
          "minLength": 1
        },
        "role": {
          "type": "string",
          "enum": [
            "orchestrator",
            "explorer",
            "coder",
            "reviewer",
            "auditor"
          ]
        },
        "error": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "UserFollowUpQueued": {
      "type": "object",
      "required": [
        "round",
        "position",
